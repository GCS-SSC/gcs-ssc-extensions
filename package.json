{
  "name": "@gcs-ssc/extensions",
  "version": "0.1.0",
  "description": "Public extension SDK contracts for GCS-SSC extensions.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/GCS-SSC/gcs-ssc-extensions.git"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "README.md",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
