    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./testing": {
      "types": "./src/testing.ts",
      "import": "./src/testing.ts"
    },
    "./nuxt": {
      "types": "./src/nuxt.ts",
      "import": "./src/nuxt.ts"
    }
  },
  "peerDependencies": {
    "kysely": "^0.28.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "kysely": "^0.28.11",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
